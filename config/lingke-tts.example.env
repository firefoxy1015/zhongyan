# Set these as Render environment variables. Do not commit the real API key.
LINGKE_API_KEY=
LINGKE_TTS_URL=https://lingkeapi.com/kling/v1/audio/tts
LINGKE_TTS_SPEED=1
LINGKE_TTS_VOICESET_ID=zhongyan-first-trial-v1

# All nine values are mandatory and must be distinct. There is no fallback voice.
LINGKE_TTS_VOICE_TIANTIAN=
LINGKE_TTS_VOICE_QIAO=
LINGKE_TTS_VOICE_XIAO=
LINGKE_TTS_VOICE_ZHAO=
LINGKE_TTS_VOICE_HAN=
LINGKE_TTS_VOICE_ZHANG=
LINGKE_TTS_VOICE_LI=
LINGKE_TTS_VOICE_LIN=
LINGKE_TTS_VOICE_QIXIA=
