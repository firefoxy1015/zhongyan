# Set these as Render environment variables. Do not commit the real API key.
LINGKE_API_KEY=
LINGKE_TTS_URL=https://lingkeapi.com/kling/v1/audio/tts
LINGKE_TTS_SPEED=1

# The nine permanent character voices are source-controlled in
# app/lib/testimony-speech.ts. They are intentionally not configurable in Render.
